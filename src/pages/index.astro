---
import Layout from '../layouts/Layout.astro';
---

<Layout>
	<main>
		<h1>Bienvenido a GymLabs</h1>
		<p>Tu centro de entrenamiento de alto rendimiento.</p>
	</main>
</Layout>

<style>
	main {
		flex: 1;
		display: flex;
		flex-direction: column;
		align-items: center;
		justify-content: center;
		text-align: center;
		padding: 4rem 2rem;
		font-family: 'Inter', sans-serif;
	}

	h1 {
		font-size: 3rem;
		color: #111;
		margin-bottom: 1rem;
	}

	p {
		color: #666;
		font-size: 1.2rem;
	}
</style>
