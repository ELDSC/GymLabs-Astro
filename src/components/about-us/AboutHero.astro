---
const image =
"https://i.ibb.co/R4bZrNnh/Gemini-Generated-Image-j5c6qpj5c6qpj5c6.png";
import Button from "../ui/Button.astro";
---

<section class="hero">

    <div class="hero-image">
        <img src={image} alt="Hero Gym" />
    </div>

    <div class="container">
        <div class="hero-text">
            <span class="badge">About GymLabs</span>

            <h1>
                Elevate Your <span>Performance</span>
            </h1>

            <p>
                At GymLabs we create premium nutrition and performance apparel
                designed for athletes who want to push their limits and achieve
                real results.
            </p>
            
        
        </div>
    </div>

</section>

<style>
    .hero {
        display: flex;
        flex-direction: column;
        width: 100%;
        background: radial-gradient(circle at top right, #0f172a, #020617);
    }
    
    /*portada*/
    .hero-image {
        width: 100%;
        height: 700px;
        object-fit: cover;
    }
    
    .hero-image img {
        width: 100%;
        height: 100%;
        object-fit: cover;
    }
    /*contenedor-texto*/
    .container {
        max-width: 1200px;
        border: 1px solid red;
        margin: auto;
        padding: 60px 5%;
    }
    
    .hero-text {
        max-width: 700px;
    }
    
    .badge {
        display: inline-block;
        padding: 6px 14px;
        border-radius: 20px;
        background: var(--bg-surface-2);
        font-size: 0.8rem;
        margin-bottom: 20px;
    }

    .hero-text h1 {
        font-size: 3.5rem;
        line-height: 1.2;
        margin-bottom: 20px;
        color: var(--text-primary);
    }

    .hero-text h1 span {
        color: var(--color-primary);
    }

    .hero-text p {
        color: var(--text-muted);
        margin-bottom: 30px;
    }


</style>