---
import Navbar from "./Navbar.astro";
import Footer from "./Footer.astro";

interface Props {
title: string;
description?: string;
}
const {
title,
description = "GymLabs - Premium Nutrition & Performance Apparel",
} = Astro.props;
---

<!doctype html>
<html lang="es">

<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content={description} />
  <title>{title} | GymLabs</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Manrope:wght@400;500;600;700;800&display=swap"
    rel="stylesheet" />
</head>

<body class="bg-[#0d0d0d] text-white font-sans">
  <Navbar />
  <main>
    <slot />
  </main>
  <Footer />
</body>

</html>

<style is:global>
  :root {
    --color-primary: #10b981;
    --color-primary-dark: #059669;
    --color-primary-glow: #10b98140;

    --bg-base: #020617;
    --bg-surface: #0f172a;
    --bg-surface-2: #1e293b;

    --text-primary: #f8fafc;
    --text-secondary: #cbd5e1;
    --text-muted: #94a3b8;

    --border-color: #1e293b;
    --font-primary: "Manrope", sans-serif;
  }

  html,
  html {
    scroll-behavior: smooth;
  }

  *,
  *::before,
  *::after {
    box-sizing: border-box;
  }

  body {
    margin: 0;
    padding: 0;
    width: 100%;
    min-height: 100vh;
    display: flex;
    flex-direction: column;
    background:
      radial-gradient(circle at top, rgba(16, 185, 129, 0.08), transparent 24%),
      var(--bg-base);
    color: var(--text-primary);
    font-family: var(--font-primary);
  }

  html,
  body {
    width: 100%;
    min-height: 100vh;
  }

  main {
    flex: 1;
  }
</style>
