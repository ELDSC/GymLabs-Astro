---
interface Props {
  name: string;
  imageUrl: string;
  price: number;
  compareAtPrice?: number | null;
  category: string;
  badge?: string;
}

const { name, imageUrl, price, compareAtPrice = null, category, badge } = Astro.props;
const formatPrice = (value: number) =>
  new Intl.NumberFormat("es-PE", {
    minimumFractionDigits: 2,
    maximumFractionDigits: 2,
  }).format(value);
---

<article class="card">
  {badge && <span class="badge">{badge}</span>}

  <div class="image-container">
    <img src={imageUrl} alt={name} loading="lazy" />
  </div>

  <div class="content">
    <p class="category">{category}</p>
    <h3>{name}</h3>
    <div class="pricing">
      {compareAtPrice && <span class="old-price">S/ {formatPrice(compareAtPrice)}</span>}
      <span class="price">S/ {formatPrice(price)}</span>
    </div>

    <button class="btn-buy" type="button">Anadir al carrito</button>
  </div>
</article>

<style>
  .card {
    background-color: var(--bg-surface, #0f172a);
    border: 1px solid var(--border-color, #1e293b);
    border-radius: 12px;
    padding: 1.25rem;
    position: relative;
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
    transition:
      transform 0.2s ease,
      border-color 0.2s ease;
  }

  .card:hover {
    transform: translateY(-5px);
    border-color: var(--color-primary, #10b981);
  }

  .badge {
    position: absolute;
    top: -12px;
    left: 50%;
    transform: translateX(-50%);
    background-color: var(--color-primary, #10b981);
    color: var(--bg-base, #020617);
    font-size: 0.75rem;
    font-weight: 800;
    padding: 4px 16px;
    border-radius: 20px;
    letter-spacing: 0.5px;
    box-shadow: 0 4px 10px var(--color-primary-glow);
  }

  .image-container {
    height: 220px;
    background-color: var(--bg-base, #020617);
    border-radius: 8px;
    overflow: hidden;
    display: flex;
    justify-content: center;
    align-items: center;
  }

  .image-container img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.3s ease;
  }

  .card:hover .image-container img {
    transform: scale(1.05);
  }

  .content {
    display: flex;
    flex: 1;
    flex-direction: column;
  }

  .category {
    margin: 0 0 0.45rem;
    color: var(--text-muted, #94a3b8);
    font-size: 0.82rem;
    letter-spacing: 0.06em;
    text-transform: uppercase;
  }

  h3 {
    margin: 0 0 0.5rem;
    font-size: 1.15rem;
    font-weight: 600;
    color: var(--text-primary, #f8fafc);
  }

  .pricing {
    display: flex;
    align-items: center;
    gap: 10px;
    margin-bottom: 1.5rem;
  }

  .old-price {
    color: var(--text-muted, #94a3b8);
    text-decoration: line-through;
    font-size: 0.95rem;
  }

  .price {
    color: var(--color-primary, #10b981);
    font-size: 1.4rem;
    font-weight: 800;
  }

  .btn-buy {
    width: 100%;
    margin-top: auto;
    background-color: rgba(16, 185, 129, 0.18);
    color: var(--text-primary);
    border: 1px solid rgba(16, 185, 129, 0.28);
    padding: 12px;
    border-radius: 8px;
    font-weight: 600;
    font-family: var(--font-primary);
    cursor: pointer;
    transition: all 0.3s;
  }

  .btn-buy:hover {
    background-color: var(--color-primary, #10b981);
    color: var(--bg-base);
    box-shadow: 0 4px 12px var(--color-primary-glow);
  }
</style>
