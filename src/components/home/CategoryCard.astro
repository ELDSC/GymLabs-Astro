---
interface Props {
  title: string;
  description: string;
  iconLabel: string;
}

const { title, description, iconLabel } = Astro.props;
---

<article class="category-card">
  <div class="category-card__icon" aria-hidden="true">{iconLabel}</div>
  <h3>{title}</h3>
  <p>{description}</p>
</article>

<style>
  .category-card {
    padding: 1.4rem 1.2rem;
    border-radius: 22px;
    border: 1px solid rgba(148, 163, 184, 0.12);
    background:
      linear-gradient(180deg, rgba(15, 23, 42, 0.96), rgba(15, 23, 42, 0.72));
    box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.02);
    text-align: center;
  }

  .category-card__icon {
    width: 3rem;
    height: 3rem;
    margin: 0 auto 1rem;
    display: grid;
    place-items: center;
    border-radius: 16px;
    background:
      radial-gradient(circle at top, rgba(16, 185, 129, 0.3), rgba(16, 185, 129, 0.08));
    color: var(--color-primary);
    font-size: 0.9rem;
    font-weight: 800;
    letter-spacing: 0.06em;
  }

  .category-card h3 {
    margin: 0;
    font-size: 1.08rem;
  }

  .category-card p {
    margin: 0.7rem 0 0;
    color: var(--text-muted);
    font-size: 0.92rem;
    line-height: 1.6;
  }
</style>
