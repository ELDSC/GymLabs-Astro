---
import ProductCard from "../ui/ProductCard.astro";

interface ProductItem {
  id: string;
  name: string;
  category: string;
  imageUrl: string;
  price: number;
  compareAtPrice?: number | null;
  badge?: string;
}

interface Props {
  products: ProductItem[];
}

const { products } = Astro.props;
---

<section class="section" id="ofertas" aria-labelledby="ofertas-title">
  <div class="section__inner">
    <div class="section__heading">
      <h2 id="ofertas-title">Ofertas destacadas</h2>
      <p>
        Mostramos solo tres productos en home, pero los destacados se obtienen
        desde Supabase usando la variable de prioridad del producto.
      </p>
    </div>

    <div class="products-grid">
      {products.map((product) => <ProductCard {...product} />)}
    </div>
  </div>
</section>

<style>
  .section {
    padding: 0 1.5rem;
  }

  .section__inner {
    max-width: 1120px;
    margin: 0 auto;
  }

  .section__heading {
    text-align: center;
    margin-bottom: 1.75rem;
  }

  .section__heading h2 {
    margin: 0;
    font-size: clamp(2rem, 4vw, 2.6rem);
    line-height: 1.1;
  }

  .section__heading p {
    margin: 0.7rem auto 0;
    max-width: 60ch;
    color: var(--text-muted);
    line-height: 1.7;
  }

  .products-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 1rem;
  }

  @media (max-width: 980px) {
    .products-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media (max-width: 600px) {
    .section {
      padding-inline: 1rem;
    }

    .products-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
