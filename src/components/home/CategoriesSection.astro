---
import CategoryCard from "./CategoryCard.astro";
import { getSupabasePublicUrl } from "../../lib/supabase";

const categories = [
  {
    id: "1",
    title: "Proteína",
    description: "Suplementos para ganar masa muscular",
    iconUrl: getSupabasePublicUrl("icons", "proteina_icon.png"),
  },
  {
    id: "2",
    title: "Creatina",
    description: "Mejora tu rendimiento",
    iconUrl: getSupabasePublicUrl("icons", "creatina_icon.png"),
  },
  {
    id: "3",
    title: "Accesorios",
    description: "Todo para tu entrenamiento",
    iconUrl: getSupabasePublicUrl("icons", "gym_accesorie.png"),
  },
  {
    id: "4",
    title: "Ropa deportiva",
    description: "Entrena con estilo",
    iconUrl: getSupabasePublicUrl("icons", "ropa_deportiva.png"),
  },
];
---

<section class="section" id="categorias" aria-labelledby="categorias-title">
  <div class="section__inner">
    <div class="section__heading">
      <h2 id="categorias-title">Nuestras categorias</h2>
      <p>
        Selecciona la linea que mejor encaja con tu objetivo y descubre una
        experiencia enfocada en rendimiento real.
      </p>
    </div>

    <div class="categories-grid">
      {
        categories.map((category) => (
          <CategoryCard
            title={category.title}
            description={category.description}
            iconUrl={category.iconUrl}
          />
        ))
      }
    </div>
  </div>
</section>

<style>
  .section {
    padding: 0 1.5rem;
  }

  .section__inner {
    max-width: 1120px;
    margin: 0 auto;
  }

  .section__heading {
    text-align: center;
    margin-bottom: 1.75rem;
  }

  .section__heading h2 {
    margin: 0;
    font-size: clamp(2rem, 4vw, 2.6rem);
    line-height: 1.1;
  }

  .section__heading p {
    margin: 0.7rem auto 0;
    max-width: 56ch;
    color: var(--text-muted);
    line-height: 1.7;
  }

  .categories-grid {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: 1rem;
  }

  @media (max-width: 980px) {
    .categories-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media (max-width: 600px) {
    .section {
      padding-inline: 1rem;
    }

    .categories-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
